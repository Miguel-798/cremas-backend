# Supabase Configuration
# Get these values from your Supabase project dashboard
DATABASE_URL=postgresql+asyncpg://postgres:<your-db-password>@db.<your-project-ref>.supabase.co:5432/postgres

# Supabase Keys
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gmail API Configuration (Google Cloud)
# Get from: Google Cloud Console > APIs & Services > Credentials
GMAIL_CLIENT_ID=your_google_cloud_client_id
GMAIL_CLIENT_SECRET=your_google_cloud_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_FROM_EMAIL=your_email@gmail.com
GMAIL_TO_EMAIL=your_email@gmail.com

# App Configuration
APP_NAME=Cremas Inventory
APP_VERSION=1.0.0
DEBUG=true
LOW_STOCK_THRESHOLD=3
RESERVATION_EXPIRY_DAYS=2

# Environment: development | production
ENV=development
